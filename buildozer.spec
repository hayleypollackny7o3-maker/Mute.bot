[app]
title = MuteBot
package.name = mutebot
package.domain = org.swill
source.dir = .
source.include_patterns = main.py
version = 0.1
requirements = telethon, python3, asyncio
orientation = portrait
fullscreen = 0
android.permissions = INTERNET, WRITE_EXTERNAL_STORAGE, READ_EXTERNAL_STORAGE

[buildozer]
log_level = 2
warn_on_root = 1
